# ── Deployment ─────────────────────────────────────────────────────
NODE_ENV=development
ENVIRONMENT=dev

# ── AWS ────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=123456789012

# ── Database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://cguser:devpass@localhost:5432/communitygate
DATABASE_URL_TEST=postgresql://cguser:devpass@localhost:5432/cg_test
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_WHITELIST_TTL_SECONDS=360

# ── MQTT (local dev = Mosquitto; production = AWS IoT Core) ────────
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USE_TLS=false
# Production overrides:
# MQTT_BROKER=xxxx-ats.iot.ap-south-1.amazonaws.com
# MQTT_PORT=8883
# MQTT_USE_TLS=true
# MQTT_CERT_PATH=/certs/device.pem
# MQTT_KEY_PATH=/certs/device.key
# MQTT_CA_PATH=/certs/AmazonRootCA1.pem

# ── Auth ───────────────────────────────────────────────────────────
COGNITO_RESIDENT_POOL_ID=ap-south-1_XXXXXXXX
COGNITO_RESIDENT_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
COGNITO_ADMIN_POOL_ID=ap-south-1_YYYYYYYY
COGNITO_ADMIN_CLIENT_ID=yyyyyyyyyyyyyyyyyyyy
JWT_ISSUER=https://cognito-idp.ap-south-1.amazonaws.com/ap-south-1_XXXXXXXX

# ── Service ports ──────────────────────────────────────────────────
PORT_API_GATEWAY=3000
PORT_VEHICLE_SERVICE=3001
PORT_VISITOR_SERVICE=3002
PORT_GATE_COMMAND=3003
PORT_NOTIFICATION=3004
PORT_AUDIT=3005
PORT_ANPR_SERVICE=8001
PORT_LOCAL_EDGE_API=8000

# ── ANPR ───────────────────────────────────────────────────────────
ANPR_SERVICE_URL=http://localhost:8001
ANPR_CONFIDENCE_THRESHOLD=0.75
ANPR_USE_GPU=false

# ── Notifications ──────────────────────────────────────────────────
MSG91_AUTH_KEY=your-msg91-key
MSG91_SENDER_ID=CGATES
MSG91_OTP_TEMPLATE_ID=your-otp-template
MSG91_ENTRY_TEMPLATE_ID=your-entry-template
FCM_PROJECT_ID=your-firebase-project-id
FCM_SERVICE_ACCOUNT_KEY_PATH=./fcm-service-account.json

# ── S3 ─────────────────────────────────────────────────────────────
S3_MEDIA_BUCKET=communitygate-media-dev
S3_SNAPSHOTS_PREFIX=snapshots/
S3_REPORTS_PREFIX=reports/
S3_SNAPSHOT_RETENTION_DAYS=30

# ── Edge node (set on each Raspberry Pi via /etc/communitygate/env) ─
GATE_ID=gate-01
COMMUNITY_ID=replace-with-uuid
DEVICE_TOKEN=replace-with-device-jwt
CLOUD_API_URL=https://api.communitygate.in/api/v1

RELAY_GPIO_PIN=17
RELAY_OPEN_SECONDS=5
MQTT_COMMAND_TTL_SECONDS=30

RFID_SPI_BUS=0
RFID_SPI_DEVICE=0
RFID_RESET_PIN=25
RFID_DEBOUNCE_SECONDS=3

OFFLINE_DB_PATH=/var/communitygate/whitelist.db
OFFLINE_QUEUE_PATH=/var/communitygate/event_queue.db
WHITELIST_SYNC_INTERVAL_SECONDS=300
HEARTBEAT_INTERVAL_SECONDS=60

# ── Mock flags (true on dev/CI; false on real Pi) ──────────────────
USE_GPIO_MOCK=true
USE_RFID_MOCK=true
USE_CAMERA_MOCK=true
MOCK_CAMERA_INTERVAL_SECONDS=4
MOCK_CAMERA_PLATE_DIR=scripts/test_plates
